{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://umberhold.local/schemas/maps/grid-map.schema.json",
  "title": "Umberhold 26x26 Grid Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "region_id",
    "map_type",
    "floor",
    "grid",
    "defaults",
    "tiles"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique map id used by content and transit links."
    },
    "name": {
      "type": "string"
    },
    "region_id": {
      "type": "string",
      "description": "Owning region or higher-level location id."
    },
    "parent_location_id": {
      "type": "string",
      "description": "Optional location or hub id this floor belongs to."
    },
    "map_type": {
      "$ref": "#/$defs/mapType"
    },
    "floor": {
      "type": "integer",
      "minimum": 0,
      "description": "0-based floor index within a location or region stack."
    },
    "theme_id": {
      "type": "string",
      "description": "Optional rendering/theme preset id."
    },
    "grid": {
      "$ref": "#/$defs/gridSpec"
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "entry_points": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/entryPoint"
      }
    },
    "tiles": {
      "$ref": "#/$defs/tileMap"
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edgeFeature"
      }
    },
    "props": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prop"
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trigger"
      }
    },
    "transits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transit"
      }
    },
    "encounter_policy": {
      "$ref": "#/$defs/encounterPolicy"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "coord": {
      "type": "string",
      "pattern": "^(?:[A-Z](?:[1-9]|1[0-9]|2[0-6]))$",
      "description": "Canonical A1-Z26 grid coordinate."
    },
    "direction": {
      "type": "string",
      "enum": ["north", "east", "south", "west"]
    },
    "mapType": {
      "type": "string",
      "enum": ["town", "dungeon", "wilderness", "interior", "set_piece"]
    },
    "gridSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "coordinate_format",
        "origin",
        "x_axis",
        "y_axis"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "const": 26
        },
        "height": {
          "type": "integer",
          "const": 26
        },
        "coordinate_format": {
          "type": "string",
          "const": "A1-Z26"
        },
        "origin": {
          "type": "string",
          "const": "top_left"
        },
        "x_axis": {
          "type": "string",
          "const": "A_to_Z"
        },
        "y_axis": {
          "type": "string",
          "const": "1_to_26"
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "texture_id": {
          "type": "string",
          "description": "Optional high-level preset texture id."
        },
        "floor_texture_id": {
          "type": "string"
        },
        "wall_texture_id": {
          "type": "string"
        },
        "ceiling_texture_id": {
          "type": "string"
        },
        "ceiling_height": {
          "type": "integer",
          "minimum": 1
        },
        "random_encounter_table": {
          "type": ["string", "null"]
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tileMap": {
      "type": "object",
      "description": "Exactly one tile payload for each coordinate from A1 to Z26.",
      "propertyNames": {
        "pattern": "^(?:[A-Z](?:[1-9]|1[0-9]|2[0-6]))$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/tile"
      },
      "minProperties": 676,
      "maxProperties": 676
    },
    "tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_wall"],
      "properties": {
        "is_wall": {
          "type": "boolean",
          "description": "Solid/non-walkable if true."
        },
        "texture_id": {
          "type": "string",
          "description": "Optional single texture preset for this tile."
        },
        "floor_texture_id": {
          "type": ["string", "null"]
        },
        "wall_texture_id": {
          "type": ["string", "null"]
        },
        "ceiling_texture_id": {
          "type": ["string", "null"]
        },
        "height": {
          "type": "integer",
          "minimum": -16,
          "maximum": 16,
          "description": "Relative floor height offset for the tile."
        },
        "ceiling_height": {
          "type": "integer",
          "minimum": 1
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "encounter_table": {
          "type": ["string", "null"],
          "description": "Tile-specific override for random encounters."
        },
        "step_trigger_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "interact_id": {
          "type": ["string", "null"]
        },
        "automap_hidden": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "entryPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "coord", "facing"],
      "properties": {
        "id": {
          "type": "string"
        },
        "coord": {
          "$ref": "#/$defs/coord"
        },
        "facing": {
          "$ref": "#/$defs/direction"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "edgeFeatureType": {
      "type": "string",
      "enum": [
        "wall",
        "door",
        "secret_door",
        "portcullis",
        "illusionary_wall",
        "one_way_barrier"
      ]
    },
    "edgeFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "at", "side", "feature"],
      "properties": {
        "id": {
          "type": "string"
        },
        "at": {
          "$ref": "#/$defs/coord"
        },
        "side": {
          "$ref": "#/$defs/direction"
        },
        "feature": {
          "$ref": "#/$defs/edgeFeatureType"
        },
        "texture_id": {
          "type": "string"
        },
        "initially_open": {
          "type": "boolean"
        },
        "locked": {
          "type": "boolean"
        },
        "lock_id": {
          "type": "string"
        },
        "key_item_id": {
          "type": "string"
        },
        "required_flags_all": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "blocked_by_flags_any": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "interact_id": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "propType": {
      "type": "string",
      "enum": [
        "stairs_up",
        "stairs_down",
        "ladder",
        "chest",
        "lever",
        "switch",
        "altar",
        "sign",
        "well",
        "statue",
        "npc_spawn",
        "decoration"
      ]
    },
    "prop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "coord", "prop_type"],
      "properties": {
        "id": {
          "type": "string"
        },
        "coord": {
          "$ref": "#/$defs/coord"
        },
        "prop_type": {
          "$ref": "#/$defs/propType"
        },
        "facing": {
          "$ref": "#/$defs/direction"
        },
        "blocks_movement": {
          "type": "boolean"
        },
        "cosmetic_only": {
          "type": "boolean"
        },
        "interact_id": {
          "type": ["string", "null"]
        },
        "required_flags_all": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "blocked_by_flags_any": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "triggerType": {
      "type": "string",
      "enum": ["on_step", "on_enter", "on_exit", "on_interact", "on_search"]
    },
    "firePolicy": {
      "type": "string",
      "enum": ["always", "once_per_save", "once_per_campaign", "once_when_enabled"]
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "trigger_type", "event_id", "fire_policy"],
      "properties": {
        "id": {
          "type": "string"
        },
        "trigger_type": {
          "$ref": "#/$defs/triggerType"
        },
        "event_id": {
          "type": "string"
        },
        "fire_policy": {
          "$ref": "#/$defs/firePolicy"
        },
        "required_flags_all": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "required_flags_any": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "blocked_by_flags_any": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "suppress_random_encounters": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "travelMode": {
      "type": "string",
      "enum": ["stairs_up", "stairs_down", "door", "gate", "ladder", "world_exit", "scripted"]
    },
    "transit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "coord",
        "travel_mode",
        "destination_map_id",
        "destination_entry_point_id"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "coord": {
          "$ref": "#/$defs/coord"
        },
        "travel_mode": {
          "$ref": "#/$defs/travelMode"
        },
        "destination_map_id": {
          "type": "string"
        },
        "destination_entry_point_id": {
          "type": "string"
        },
        "required_flags_all": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "blocked_by_flags_any": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "label": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "encounterPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_table_id": {
          "type": ["string", "null"]
        },
        "safe_coords": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/coord"
          }
        },
        "suppress_on_trigger_tiles": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
