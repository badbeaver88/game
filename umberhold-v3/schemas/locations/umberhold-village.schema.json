{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://umberhold.local/schemas/locations/umberhold-village.schema.json",
  "title": "Umberhold Village Content Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "overview",
    "design_intent",
    "journal_ui",
    "locations",
    "npcs",
    "quests",
    "progression"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "umberhold"
    },
    "name": {
      "type": "string",
      "const": "Umberhold"
    },
    "overview": {
      "type": "string"
    },
    "design_intent": {
      "$ref": "#/$defs/designIntent"
    },
    "journal_ui": {
      "$ref": "#/$defs/journalUi"
    },
    "locations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/location"
      }
    },
    "npcs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/npc"
      }
    },
    "quests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/quest"
      }
    },
    "progression": {
      "$ref": "#/$defs/progression"
    }
  },
  "$defs": {
    "journalUi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["icon", "available_in", "blocked_in_combat"],
      "properties": {
        "icon": {
          "type": "string",
          "const": "book"
        },
        "available_in": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["village", "exploration", "combat"]
          }
        },
        "blocked_in_combat": {
          "type": "boolean"
        }
      }
    },
    "designIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structure", "intended_first_path", "soft_gating", "difficulty_signposting"],
      "properties": {
        "structure": {
          "type": "string",
          "enum": ["sandbox_hub"]
        },
        "intended_first_path": {
          "type": "string"
        },
        "soft_gating": {
          "type": "boolean"
        },
        "failure_expected": {
          "type": "boolean"
        },
        "difficulty_signposting": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["content_id", "message"],
            "properties": {
              "content_id": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "serviceOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "effect"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "effect": {
          "type": "string"
        },
        "cost_gp": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "location_type", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "location_type": {
          "type": "string",
          "enum": [
            "service_hub",
            "quest_site",
            "set_piece_combat",
            "single_level_dungeon_entrance",
            "progression_lock"
          ]
        },
        "summary": {
          "type": "string"
        },
        "npc_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "services": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/serviceOption"
          }
        },
        "interaction_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "encounter_transition": {
          "type": "string"
        },
        "unlock_flag": {
          "type": "string"
        },
        "journal_trigger": {
          "type": "string"
        }
      }
    },
    "npcDialogueSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "after_missing_alchemist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "after_restless_dead": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "after_troll_trouble": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "after_all_three": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "npc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "suspicious_detail": {
          "type": "string"
        },
        "dialogue": {
          "$ref": "#/$defs/npcDialogueSet"
        },
        "unlocks_after_flag": {
          "type": "string"
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "reward": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gp": {
          "type": "integer",
          "minimum": 0
        },
        "lesser_item_rolls": {
          "type": "integer",
          "minimum": 0
        },
        "greater_item_rolls": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "quest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "quest_type",
        "difficulty_hint",
        "source_summary",
        "journal_summary_incomplete",
        "journal_summary_complete",
        "objectives",
        "reward"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "quest_type": {
          "type": "string",
          "enum": ["main", "side"]
        },
        "difficulty_hint": {
          "type": "string",
          "enum": ["intended_first_path", "high", "very_high"]
        },
        "available_early": {
          "type": "boolean"
        },
        "ideal_after_manor": {
          "type": "boolean"
        },
        "source_npc_id": {
          "type": "string"
        },
        "source_summary": {
          "type": "string"
        },
        "journal_summary_incomplete": {
          "type": "string"
        },
        "journal_summary_complete": {
          "type": "string"
        },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/objective"
          }
        },
        "reward": {
          "$ref": "#/$defs/reward"
        },
        "village_consequences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hidden_truth": {
          "type": "string"
        }
      }
    },
    "progression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["south_gate_locked_until_flag", "recommended_order", "village_flags"],
      "properties": {
        "south_gate_locked_until_flag": {
          "type": "string"
        },
        "recommended_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "village_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
